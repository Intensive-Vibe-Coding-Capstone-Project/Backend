# Cue backend — environment template. Copy to `.env` and fill in.
# NEVER commit `.env`. All config is read via pydantic-settings (src/cue/config.py).

# --- App ---
CUE_ENV=dev                 # dev | prod
CUE_LOG_LEVEL=INFO

# --- Google Gemini (google-genai SDK) ---
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
CUE_RESCUE_MODEL=gemini-2.5-flash
CUE_REASONING_MODEL=gemini-2.5-pro
CUE_EMBEDDING_MODEL=gemini-embedding-001

# --- Ingestion ---
CUE_MAX_UPLOAD_MB=20        # reject uploads larger than this
CUE_PREVIEW_CHARS=200       # chars of parsed text returned in metadata preview

# --- Sessions / output ---
CUE_DB_PATH=cue.db          # sqlite file for session + turn history
CUE_LYRIC_MAX_CHARS=42      # max characters per rendered rescue line

# --- Transcript / triggers ---
CUE_TRANSCRIPT_WINDOW_S=30  # recent transcript window scanned for a rescue
CUE_SILENCE_THRESHOLD_S=10  # silence longer than this can trigger a rescue
CUE_SCAN_INTERVAL_S=30      # periodic auto-scan cadence
CUE_TRIGGER_MIN_CHARS=20    # ignore windows shorter than this on auto-scan
CUE_SLIP_MIN_OVERLAP=0.3    # off-flow if < this fraction of spoken words are in the script

# --- Embeddings ---
# auto = use Gemini when GEMINI_API_KEY is set, else an offline fake embedder.
CUE_EMBEDDINGS_PROVIDER=auto   # auto | gemini | fake
CUE_EMBEDDING_DIM=256          # fake embedder dimension only
CUE_EMBEDDING_BATCH_SIZE=100

# --- RAG / retrieval ---
CUE_CHROMA_DIR=.chroma         # local persistent vector store
CUE_CHROMA_COLLECTION=cue_documents
CUE_CHUNK_SIZE=800             # chars per chunk
CUE_CHUNK_OVERLAP=120
CUE_RETRIEVAL_K=5              # top-k passages per rescue

# --- Rescue / generation ---
CUE_GENERATION_PROVIDER=auto    # auto | gemini | fake (auto = gemini iff key set)
CUE_RESCUE_TEMPERATURE=0.3      # low, for faithful grounded phrasing
CUE_RESCUE_MAX_PASSAGES=5       # passages shown to the model
CUE_RESCUE_MAX_OUTPUT_TOKENS=512
CUE_RESCUE_MIN_SCORE=0.4        # cheap floor; refusal detection is the real grounding guard
CUE_RESCUE_TIMEOUT_S=4          # rescue latency budget (system-design)
