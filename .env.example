# Cue backend — environment template. Copy to `.env` and fill in.
# NEVER commit `.env`. All config is read via pydantic-settings (src/cue/config.py).

# --- App ---
CUE_ENV=dev                 # dev | prod
CUE_LOG_LEVEL=INFO

# --- Google Gemini (google-genai SDK) ---
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
CUE_RESCUE_MODEL=gemini-2.5-flash
CUE_REASONING_MODEL=gemini-2.5-pro
CUE_EMBEDDING_MODEL=gemini-embedding-001

# --- RAG / retrieval ---
CUE_CHROMA_DIR=.chroma      # local persistent vector store
CUE_CHUNK_SIZE=800          # chars per chunk (tune D3)
CUE_CHUNK_OVERLAP=120
CUE_RETRIEVAL_K=5           # top-k passages per rescue

# --- Latency / generation ---
CUE_RESCUE_TIMEOUT_S=4      # rescue latency budget (system-design)
